{
  "functions": {
    "app/api/**/*": {
      "memory": 1024,
      "maxDuration": 10,
      "runtime": "@vercel/node@3.0.0",
      "excludeFiles": "{**/*.{md,d.ts,map,test.js,spec.js},**/tests/**,**/__tests__/**,**/node_modules/{@swc,@esbuild,typescript,@types,tslib,next/dist}/**}"
    }
  },
  "crons": [],
  "buildCommand": "next build",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1",
      "NODE_ENV": "production"
    }
  },
  "outputDirectory": ".next",
  "cleanUrls": true,
  "trailingSlash": false
} 