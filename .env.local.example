# Supabase (Your values will differ)
SUPABASE_URL=https://your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Investment Analysis Service (Node.js) - For investment analysis with OpenAI
ANALYSIS_SERVICE_URL=https://your-investment-analysis-service.railway.app
# ANALYSIS_SERVICE_URL=https://investment-analysis-service-production.up.railway.app  # In production

# Market Data API (Python) - For stock and crypto prices
MARKET_SERVICE_URL=http://localhost:8000
# MARKET_SERVICE_URL=https://your-market-service.railway.app  # In production
# Legacy alias (supported by older setups):
# MARKET_DATA_URL=https://your-market-service.railway.app

# API key for authentication (used for both services)
ANALYSIS_SERVICE_API_KEY=your-api-key-here

# Optional: OpenAI (If used)
# OPENAI_API_KEY=your-openai-key 

# Supabase credentials (service role key)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Legacy alias (supported by market-service):
# SUPABASE_KEY=your-supabase-service-role-key

# Internal API Security
NEXT_PUBLIC_INTERNAL_REQUEST_TOKEN=your-internal-request-token 